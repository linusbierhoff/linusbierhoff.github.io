---
const socials = [
  {
    name: "GitHub",
    url: "https://github.com/linusbierhoff",
    icon: "github",
  },
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/in/linus-bierhoff-a63a66244/",
    icon: "linkedin",
  },
  {
    name: "ResearchGate",
    url: "https://www.researchgate.net/profile/Linus-Bierhoff",
    icon: "researchgate",
  },
  {
    name: "Email",
    url: "mailto:mail@linusbierhoff.com",
    icon: "mail",
  },
];
---

<section id="contact" class="container">
  <div class="header">
    <h2>Connect</h2>
    <div class="line"></div>
  </div>

  <div class="footer-content">
    <p class="footer-bio">
      Currently based in Karlsruhe, Germany. Feel free to get in touch!
    </p>

    <div class="social-links">
      {
        socials.map((social) => (
          <a
            href={social.url}
            target="_blank"
            class="social-btn"
            aria-label={social.name}
          >
            <span class="social-name">{social.name}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .header {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  h2 {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--secondary);
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .line {
    height: 1px;
    background: var(--border);
    flex-grow: 1;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 5rem;
  }

  .footer-bio {
    max-width: 700px;
    font-size: 1.4rem;
    color: var(--text-muted);
    line-height: 1.5;
    font-weight: 500;
  }

  .social-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .social-btn {
    padding: 1.1rem 3.5rem;
    border-radius: var(--radius);
    font-weight: 800;
    font-size: 1rem;
    background: #ffffff;
    border: 1px solid var(--border);
    color: var(--text);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: "JetBrains Mono", monospace;
  }

  .social-btn:hover {
    transform: translate(-4px, -4px);
    background: var(--primary);
    color: #ffffff;
    box-shadow: 4px 4px 0 0 var(--primary-accent);
  }

  .copyright {
    font-size: 0.75rem;
    font-weight: 700;
    color: #94a3b8;
    margin-top: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: "JetBrains Mono", monospace;
  }

  @media (max-width: 640px) {
    .social-links {
      flex-direction: column;
      width: 100%;
    }

    .social-btn {
      width: 100%;
    }
  }
</style>
