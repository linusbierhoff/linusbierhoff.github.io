---
const projects = [
    {
        title: "AMSL-App",
        description:
            "A mobile learning companion for university students, integrating advanced AI capabilities to enhance the learning experience. AMSL offers individualized student assistance based on generative AI for free learning and exam preparation.",
        link: "https://amsl.app",
        link_label: "Visit Website",
        tags: ["Rust", "Flutter", "TypeScript", "Vue", "pgvector", "OpenAI"],
    },
    {
        title: "Topic-Shift",
        description:
            "An agentic pipeline designed to extract and structure topics and contents from learning materials automatically. They system builds a knowledge graph based on the extracted information, to further develop agents or applications that can leverage the structured knowledge.",
        link: "https://github.com/linusbierhoff/topic_shift",
        link_label: "Source Code",
        tags: ["Python", "Haystack", "docling", "OpenAI", "TypeScript", "Vue"],
    },
    {
        title: "Manim-Agent",
        description:
            "An agentic pipeline for learning video production, leveraging LLMs to automate the creation of educational content.",
        link: "https://github.com/linusbierhoff/manim-agent",
        link_label: "Source Code",
        tags: ["Python", "LangGraph", "OpenAI"],
    },
];
---

<section id="projects" class="container">
    <div class="header">
        <h2>Projects</h2>
        <div class="line"></div>
    </div>

    <div class="grid">
        {
            projects.map((project) => (
                <a href={project.link} target="_blank" class="card glass">
                    <div class="card-content">
                        <div class="tags">
                            {project.tags.map((tag) => (
                                <span class="tag">{tag}</span>
                            ))}
                        </div>
                        <h3>{project.title}</h3>
                        <p>{project.description}</p>
                        <span class="view-link">{project.link_label} &rarr;</span>
                    </div>
                </a>
            ))
        }
    </div>
</section>

<style>
    .header {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 1.5rem;
    }

    h2 {
        font-size: 2.25rem;
        font-weight: 800;
        white-space: nowrap;
        color: var(--secondary);
        letter-spacing: -0.04em;
        text-transform: uppercase;
    }

    .line {
        height: 1px;
        background: var(--border);
        flex-grow: 1;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2rem;
    }

    .card {
        border-radius: var(--radius);
        padding: 3rem;
        background: #ffffff;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        border: 1px solid var(--border-muted);
        box-shadow: none;
        position: relative;
    }

    .card:hover {
        transform: translate(-4px, -4px);
        border-color: var(--primary);
        box-shadow: 4px 4px 0 0 var(--primary);
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 2rem;
    }

    .tag {
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--text);
        background: var(--primary-soft);
        padding: 0.35rem 0.75rem;
        border-radius: var(--radius);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-family: "JetBrains Mono", monospace;
        border: 1px solid var(--border-muted);
    }

    h3 {
        font-size: 1.6rem;
        margin-bottom: 1rem;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.02em;
    }

    p {
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 2.5rem;
        font-size: 1rem;
    }

    .view-link {
        font-size: 0.85rem;
        font-weight: 800;
        color: var(--primary-accent);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: underline;
        text-underline-offset: 4px;
    }
</style>
